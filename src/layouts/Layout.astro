---
import { ClientRouter } from 'astro:transitions';
import unbounded700 from '@fontsource/unbounded/files/unbounded-latin-700-normal.woff2?url';
import literataItalic from '@fontsource/literata/files/literata-latin-400-italic.woff2?url';
import jbMono from '@fontsource/jetbrains-mono/files/jetbrains-mono-latin-400-normal.woff2?url';
import '@fontsource/unbounded/500.css';
import '@fontsource/unbounded/600.css';
import '@fontsource/unbounded/700.css';
import '@fontsource/literata/400.css';
import '@fontsource/literata/400-italic.css';
import '@fontsource/literata/600.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

function mulberry32(seed: number) {
  return () => {
    seed |= 0; seed = (seed + 0x6d2b79f5) | 0;
    let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}

const rand = mulberry32(20260702);

function starColor(r: () => number) {
  const k = r();
  if (k < 0.1) return 'oklch(0.8 0.15 70)';
  if (k < 0.22) return 'oklch(0.85 0.08 215)';
  return 'oklch(0.9 0.02 250)';
}

const makeStars = (n: number, rMin: number, rMax: number) =>
  Array.from({ length: n }, () => ({
    x: +(rand() * 100).toFixed(2),
    y: +(rand() * 130).toFixed(2),
    r: +(rMin + rand() * (rMax - rMin)).toFixed(3),
    o: +(0.3 + rand() * 0.55).toFixed(2),
    c: starColor(rand),
  }));

const farStars = makeStars(150, 0.05, 0.1);
const midStars = makeStars(70, 0.08, 0.15);
const nearStars = makeStars(30, 0.12, 0.2);

const bandStars = Array.from({ length: 110 }, () => {
  const t = rand();
  const spread = (rand() + rand() + rand() - 1.5) * 9;
  const bx = -8 + t * 116;
  const by = 88 - t * 62 + spread;
  return { x: +bx.toFixed(2), y: +by.toFixed(2), r: +(0.04 + rand() * 0.09).toFixed(3), o: +(0.25 + rand() * 0.5).toFixed(2) };
});

const galaxies = [
  { x: 22, y: 24, rot: -32, s: 1 },
  { x: 84, y: 96, rot: 18, s: 0.7 },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" href={unbounded700} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={literataItalic} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={jbMono} as="font" type="font/woff2" crossorigin />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="Pietro Marchesi · writeups" href={new URL('rss.xml', Astro.site)} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={new URL('og.png', Astro.site)} />
    <meta name="twitter:card" content="summary_large_image" />
    <ClientRouter />
  </head>
  <body>
    <div class="sky" aria-hidden="true">
      <svg class="sky-layer" data-depth="0.025" viewBox="0 0 100 130" preserveAspectRatio="xMidYMid slice">
        <defs>
          <filter id="blur-lg" x="-60%" y="-60%" width="220%" height="220%"><feGaussianBlur stdDeviation="2.6" /></filter>
          <filter id="blur-md" x="-60%" y="-60%" width="220%" height="220%"><feGaussianBlur stdDeviation="1.3" /></filter>
          <filter id="blur-sm" x="-60%" y="-60%" width="220%" height="220%"><feGaussianBlur stdDeviation="0.45" /></filter>
        </defs>
        <g transform="rotate(-28 50 50)">
          <ellipse cx="50" cy="55" rx="75" ry="15" fill="oklch(0.78 0.03 250)" opacity="0.04" filter="url(#blur-lg)" />
          <ellipse cx="46" cy="54" rx="55" ry="7.5" fill="oklch(0.85 0.04 220)" opacity="0.05" filter="url(#blur-lg)" />
          <ellipse cx="60" cy="57" rx="30" ry="3.5" fill="oklch(0.9 0.04 90)" opacity="0.045" filter="url(#blur-md)" />
          <ellipse cx="34" cy="56" rx="14" ry="2.2" fill="oklch(0.2 0.03 265)" opacity="0.35" filter="url(#blur-md)" />
        </g>
        {bandStars.map((s) => (
          <circle cx={s.x} cy={s.y} r={s.r} fill="oklch(0.9 0.02 250)" opacity={Math.min(0.85, s.o + 0.15)} />
        ))}
        <ellipse cx="14" cy="78" rx="11" ry="8" fill="oklch(0.6 0.09 215)" opacity="0.05" filter="url(#blur-lg)" />
        <ellipse cx="78" cy="18" rx="9" ry="6.5" fill="oklch(0.55 0.1 350)" opacity="0.045" filter="url(#blur-lg)" />
        <ellipse cx="55" cy="118" rx="10" ry="7" fill="oklch(0.65 0.1 70)" opacity="0.04" filter="url(#blur-lg)" />
        {galaxies.map((g) => (
          <g transform={`translate(${g.x} ${g.y}) rotate(${g.rot}) scale(${g.s})`}>
            <ellipse cx="0" cy="0" rx="2.6" ry="0.8" fill="oklch(0.85 0.04 250)" opacity="0.5" filter="url(#blur-sm)" />
            <ellipse cx="0" cy="0" rx="1.4" ry="0.45" fill="oklch(0.92 0.05 90)" opacity="0.65" filter="url(#blur-sm)" />
            <circle cx="0" cy="0" r="0.28" fill="oklch(0.95 0.04 90)" opacity="0.9" />
          </g>
        ))}
        {farStars.map((s) => (
          <circle cx={s.x} cy={s.y} r={s.r} fill={s.c} opacity={s.o} />
        ))}
      </svg>
      <svg class="sky-layer" data-depth="0.06" viewBox="0 0 100 130" preserveAspectRatio="xMidYMid slice">
        {midStars.map((s) => (
          <circle cx={s.x} cy={s.y} r={s.r} fill={s.c} opacity={s.o} />
        ))}
      </svg>
      <svg class="sky-layer" data-depth="0.11" viewBox="0 0 100 130" preserveAspectRatio="xMidYMid slice">
        {nearStars.map((s) => (
          <circle cx={s.x} cy={s.y} r={s.r} fill={s.c} opacity={s.o} />
        ))}
      </svg>
    </div>

    <nav>
      <a href="/" class="nav-logo" aria-label="Home">
        <svg width="26" height="26" viewBox="0 0 26 26" aria-hidden="true">
          <circle cx="13" cy="13" r="3.2" fill="var(--amber)" />
          <ellipse cx="13" cy="13" rx="11" ry="5.5" fill="none" stroke="var(--cyan)" stroke-width="1" transform="rotate(-24 13 13)" />
          <circle cx="4" cy="17.5" r="1.4" fill="var(--cyan)" />
        </svg>
      </a>
      <div class="nav-links">
        <a href="/writeups/">writeups</a>
        <a href="/chart/">chart</a>
        <a href="/now/">now</a>
        <a href="/uses/">uses</a>
      </div>
    </nav>

    <slot />

    <footer>
      <p class="mono-label">Pietro Marchesi · Vobarno, Italy · <a href="/colophon/">colophon</a></p>
    </footer>
  </body>
</html>

<style>
  .sky {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    pointer-events: none;
  }

  .sky-layer {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 132%;
    will-change: transform;
  }

  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-nav);
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.5rem;
    background: color-mix(in oklch, var(--void) 78%, transparent);
    backdrop-filter: blur(8px);
  }

  .nav-logo {
    display: grid;
    place-items: center;
    line-height: 0;
  }

  .nav-logo svg {
    transition: transform 0.5s var(--ease-expo);
  }

  .nav-logo:hover svg {
    transform: rotate(180deg);
  }

  .nav-links {
    display: flex;
    gap: 1.8rem;
  }

  .nav-links a {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--body);
    text-decoration: none;
    position: relative;
  }

  .nav-links a::after {
    content: '';
    position: absolute;
    left: 0;
    right: 100%;
    bottom: -3px;
    height: 1px;
    background: var(--cyan);
    transition: right 0.3s var(--ease-quart);
  }

  .nav-links a:hover {
    color: var(--cyan);
  }

  .nav-links a:hover::after {
    right: 0;
  }

  footer {
    padding: 3rem 1.5rem 2.5rem;
    text-align: center;
  }
</style>

<script>
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduced) {
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const cap = window.innerHeight * 0.3;
        for (const layer of document.querySelectorAll<SVGElement>('.sky-layer')) {
          const shift = Math.min(window.scrollY * parseFloat(layer.dataset.depth!), cap);
          layer.style.transform = `translateY(${-shift}px)`;
        }
        ticking = false;
      });
    }, { passive: true });

    const meteor = () => {
      const el = document.createElement('div');
      el.className = 'meteor';
      const x = 10 + Math.random() * 70;
      const y = 5 + Math.random() * 35;
      const angle = 15 + Math.random() * 30;
      const dist = 260 + Math.random() * 240;
      el.style.left = `${x}vw`;
      el.style.top = `${y}vh`;
      el.style.rotate = `${angle}deg`;
      document.body.appendChild(el);
      el.animate(
        [
          { transform: 'translateX(0)', opacity: 0 },
          { opacity: 0.9, offset: 0.15 },
          { transform: `translateX(${dist}px)`, opacity: 0 },
        ],
        { duration: 1000 + Math.random() * 400, easing: 'linear' }
      ).onfinish = () => el.remove();
    };

    const schedule = () => {
      setTimeout(() => {
        if (!document.hidden) meteor();
        schedule();
      }, 20000 + Math.random() * 20000);
    };
    schedule();
  }
</script>
