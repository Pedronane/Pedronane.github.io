---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const writeups = await getCollection('writeups', ({ data }) => !data.draft);
  return writeups.map((w) => ({ params: { slug: w.id }, props: { writeup: w } }));
}

const { writeup } = Astro.props;
const { Content } = await render(writeup);
const fmt = new Intl.DateTimeFormat('en', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout title={`${writeup.data.title} · Pietro Marchesi`} description={writeup.data.description}>
  <main class="prose page">
    <p class="mono-label meta">
      {fmt.format(writeup.data.pubDate)} · {writeup.data.platform}
      {writeup.data.tags.length > 0 && ` · ${writeup.data.tags.join(' · ')}`}
    </p>
    <h1>{writeup.data.title}</h1>
    <Content />
    <p class="back"><a href="/writeups/">← back to the flight log</a></p>
  </main>
</Layout>

<style>
  .page {
    padding-top: clamp(7rem, 16vh, 10rem);
    padding-bottom: var(--space-section);
  }

  h1 {
    font-size: clamp(1.6rem, 4vw, 2.3rem);
    font-weight: 700;
    margin-bottom: 2rem;
  }

  .meta {
    color: var(--cyan);
    margin-bottom: 0.8rem;
  }

  .back {
    margin-top: 3rem;
    font-family: var(--font-mono);
    font-size: 0.88rem;
  }
</style>
