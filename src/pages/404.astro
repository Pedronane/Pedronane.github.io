---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 · lost in space" description="This page drifted beyond the observable site.">
  <section class="lost">
    <canvas id="nbody" aria-hidden="true"></canvas>
    <div class="lost-text">
      <p class="mono-label">error 404</p>
      <h1>Lost in space</h1>
      <p class="lost-sub">
        This page drifted beyond the observable site. Even the simulation above has
        given up on gravity.
      </p>
      <a href="/" class="return mono-label">← return to orbit</a>
    </div>
  </section>
</Layout>

<style>
  .lost {
    position: relative;
    min-height: 100svh;
    display: grid;
    place-items: center;
  }

  #nbody {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .lost-text {
    position: relative;
    text-align: center;
    padding: 0 1.5rem;
  }

  .lost-text .mono-label {
    color: var(--amber);
  }

  h1 {
    font-size: clamp(1.9rem, 6vw, 3.6rem);
    font-weight: 700;
    margin-top: 0.6rem;
  }

  .lost-sub {
    margin: 1.2rem auto 0;
    max-width: 34rem;
    text-shadow: 0 0 24px oklch(0.13 0.035 275);
  }

  .return {
    display: inline-block;
    margin-top: 2.2rem;
    color: var(--cyan);
    border: 1px solid var(--line);
    padding: 0.6rem 1.4rem;
    border-radius: 4px;
    text-decoration: none;
    transition: border-color 0.2s var(--ease-quart);
  }

  .return:hover {
    border-color: var(--cyan);
  }
</style>

<script>
  import { startSim } from '../scripts/nbody';

  const sim = startSim(document.getElementById('nbody') as HTMLCanvasElement);
  sim.invertGravity();
</script>
