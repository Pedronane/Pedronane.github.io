      { x: 420, y: 260, label: 'ひらがな', note: 'the first alphabet fell', lit: true },
      { x: 490, y: 290, label: 'カタカナ', note: 'the second one too', lit: true },
      { x: 560, y: 265, label: 'Tae Kim', note: 'grammar, chapter by chapter', lit: true },
