---
import { PLANETS } from '../scripts/solar';

const DEST: Record<string, string> = {
  flags: 'writeups',
  kernels: 'uses',
  '言': 'chart',
  chords: 'chart',
  ink: 'chart',
  kepler: 'github',
};
---

<section class="hero">
  <canvas id="nbody" aria-hidden="true"></canvas>
  <div class="hero-text">
    <h1>Pietro Marchesi</h1>
    <p class="tagline">Exploring systems — from kernels to Kepler.</p>
    <p class="hero-hint mono-label">drag to launch a comet<span class="sudo-hint"> · type <code>sudo</code> if you dare</span></p>
  </div>
  <nav class="system-index mono-label" aria-label="System map">
    {PLANETS.map((p) => (
      <a href={p.href} data-planet={p.name}>
        <span class="dot" style={`background: ${p.color}`}></span>
        {p.name}<span class="dest"> · {DEST[p.name]}</span>
      </a>
    ))}
  </nav>
  <div class="gravity-toast mono-label" id="gravity-toast" role="status">gravity inverted</div>
  <a href="#about" class="scroll-hint" aria-label="Scroll to about">
    <svg width="18" height="26" viewBox="0 0 18 26" aria-hidden="true">
      <path d="M9 4 v14 M4 13 l5 6 5-6" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: grid;
    place-items: center;
  }

  #nbody {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    touch-action: pan-y;
  }

  .hero-text {
    position: relative;
    text-align: center;
    padding: 0 1.5rem;
    animation: rise 0.7s var(--ease-expo) backwards;
    pointer-events: none;
    transition: transform 0.8s var(--ease-expo);
    z-index: 11;
  }

  .hero-text.playing {
    transform: translate(var(--dock-x, 0px), var(--dock-y, -38svh)) scale(0.34);
  }

  .tagline,
  .hero-hint {
    transition: opacity 0.4s var(--ease-quart);
  }

  .hero-text.playing .tagline,
  .hero-text.playing .hero-hint {
    opacity: 0;
  }

  @keyframes rise {
    from { opacity: 0; transform: translateY(14px); }
    to { opacity: 1; transform: none; }
  }

  h1 {
    font-size: clamp(1.9rem, 6.5vw, 4.2rem);
    font-weight: 700;
    letter-spacing: -0.01em;
    text-shadow: 0 0 40px oklch(0.13 0.035 275 / 0.9);
  }

  .tagline {
    font-style: italic;
    font-size: clamp(1.05rem, 2.2vw, 1.35rem);
    color: var(--body);
    margin: 1rem auto 0;
    text-shadow: 0 0 24px oklch(0.13 0.035 275);
  }

  .hero-hint {
    margin: 2.4rem auto 0;
  }

  .hero-hint code {
    background: none;
    padding: 0;
    color: var(--amber);
  }

  @media (hover: none) {
    .sudo-hint { display: none; }
  }

  .system-index {
    position: absolute;
    left: 2rem;
    bottom: 2.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .system-index a {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--body);
    text-decoration: none;
    font-size: 0.82rem;
    transition: color 0.2s var(--ease-quart);
  }

  .system-index a:hover {
    color: var(--ink);
  }

  .system-index .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
    transition: box-shadow 0.2s var(--ease-quart);
  }

  .system-index a:hover .dot {
    box-shadow: 0 0 8px 1px color-mix(in oklch, var(--cyan) 60%, transparent);
  }

  .system-index .dest {
    color: var(--faint);
  }

  @media (max-width: 720px) {
    .system-index {
      left: 50%;
      translate: -50% 0;
      bottom: 4.6rem;
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
      column-gap: 1.1rem;
      row-gap: 0.4rem;
      padding-inline: 1rem;
    }

    .system-index .dest {
      display: none;
    }
  }

  .scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    translate: -50% 0;
    color: var(--faint);
    animation: drift 2.4s ease-in-out infinite;
  }

  @media (max-width: 720px) {
    .scroll-hint {
      display: none;
    }
  }

  .scroll-hint:hover { color: var(--cyan); }

  @keyframes drift {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  .gravity-toast {
    position: absolute;
    top: 5.5rem;
    left: 50%;
    translate: -50% 0;
    color: var(--amber);
    border: 1px solid var(--line);
    background: var(--surface);
    padding: 0.4rem 1rem;
    border-radius: 4px;
    opacity: 0;
    transition: opacity 0.3s var(--ease-quart);
    pointer-events: none;
  }

  .gravity-toast.show { opacity: 1; }

  @media (prefers-reduced-motion: reduce) {
    .hero-text { animation: none; }
    .scroll-hint { animation: none; }
  }
</style>

<script>
  import { startSolar, type SolarSim } from '../scripts/solar';

  let sim: SolarSim | null = null;

  const KONAMI = ['ArrowUp','ArrowUp','ArrowDown','ArrowDown','ArrowLeft','ArrowRight','ArrowLeft','ArrowRight','b','a'];
  let progress = 0;
  let toastTimer = 0;

  document.addEventListener('keydown', (e) => {
    if (!sim) return;
    progress = e.key === KONAMI[progress] ? progress + 1 : (e.key === KONAMI[0] ? 1 : 0);
    if (progress === KONAMI.length) {
      progress = 0;
      const inverted = sim.invertGravity();
      const toast = document.getElementById('gravity-toast');
      if (!toast) return;
      toast.textContent = inverted ? 'gravity inverted — good luck out there' : 'gravity restored';
      toast.classList.add('show');
      clearTimeout(toastTimer);
      toastTimer = window.setTimeout(() => toast.classList.remove('show'), 2600);
    }
  });

  document.addEventListener('astro:page-load', () => {
    const canvas = document.getElementById('nbody') as HTMLCanvasElement | null;
    if (!canvas || canvas.dataset.init) return;
    canvas.dataset.init = '1';
    const heroText = document.querySelector<HTMLElement>('.hero-text')!;
    const h1 = heroText.querySelector('h1')!;
    const SCALE = 0.34;

    const dockVars = () => {
      if (heroText.classList.contains('playing')) return;
      const box = heroText.getBoundingClientRect();
      const r = h1.getBoundingClientRect();
      const boxCx = box.left + box.width / 2;
      const boxCy = box.top + box.height / 2;
      const h1Cx = r.left + r.width / 2;
      const h1Cy = r.top + r.height / 2;
      const targetCx = 62 + (r.width * SCALE) / 2;
      const targetCy = 29;
      heroText.style.setProperty('--dock-x', `${targetCx - boxCx - (h1Cx - boxCx) * SCALE}px`);
      heroText.style.setProperty('--dock-y', `${targetCy - boxCy - (h1Cy - boxCy) * SCALE}px`);
    };
    dockVars();
    window.addEventListener('resize', () => setTimeout(dockVars, 200));

    sim = startSolar(canvas, {
      onPlay(playing) {
        if (playing) dockVars();
        heroText.classList.toggle('playing', playing);
      },
    });

    for (const link of document.querySelectorAll<HTMLAnchorElement>('.system-index a')) {
      link.addEventListener('mouseenter', () => sim?.highlight(link.dataset.planet!));
      link.addEventListener('mouseleave', () => sim?.highlight(null));
    }
  });

  document.addEventListener('astro:before-swap', () => {
    sim?.destroy();
    sim = null;
  });
</script>
