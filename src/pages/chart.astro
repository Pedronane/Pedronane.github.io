---
import Layout from '../layouts/Layout.astro';

interface Star {
  x: number;
  y: number;
  label: string;
  note: string;
  lit: boolean;
  quest?: string;
}

interface Constellation {
  id: string;
  name: string;
  color: string;
  labelAt: [number, number];
  stars: Star[];
}

const constellations: Constellation[] = [
  {
    id: 'flags',
    name: 'FLAGS · cybersecurity',
    color: 'oklch(0.72 0.14 25)',
    labelAt: [120, 240],
    stars: [
      { x: 95, y: 120, label: 'picoCTF', note: 'first flags ever captured', lit: true },
      { x: 175, y: 90, label: 'OverTheWire', note: 'where ssh became muscle memory', lit: true },
      { x: 250, y: 140, label: 'TryHackMe', note: 'rooms, paths, late nights', lit: true },
      { x: 205, y: 200, label: 'first HTB box', note: 'waiting for me', lit: false, quest: 'root one retired easy box, write it up' },
      { x: 300, y: 215, label: 'eJPT', note: 'first certification on the roadmap', lit: false, quest: 'finish the INE path, book the voucher' },
      { x: 380, y: 165, label: 'OSCP', note: 'the distant bright one', lit: false, quest: 'earned only after eJPT and ~100 boxes' },
    ],
  },
  {
    id: 'orbit',
    name: 'ORBIT · space',
    color: 'oklch(0.7 0.1 265)',
    labelAt: [530, 60],
    stars: [
      { x: 470, y: 110, label: 'Euler', note: 'first integrator, gravity sandbox M1', lit: true },
      { x: 545, y: 140, label: 'Verlet', note: 'energy finally conserved, M4', lit: true },
      { x: 620, y: 105, label: 'this website', note: 'the hero up there runs my physics', lit: true },
      { x: 700, y: 130, label: 'Kepler problem', note: 'orbits from first principles', lit: false, quest: 'derive the ellipse from F=GMm/r² — M8→M13' },
      { x: 780, y: 80, label: 'ESA', note: 'somewhere that launches things', lit: false, quest: 'degree first. then everything else.' },
    ],
  },
  {
    id: 'chords',
    name: 'CHORDS · guitar',
    color: 'oklch(0.78 0.13 55)',
    labelAt: [820, 290],
    stars: [
      { x: 760, y: 210, label: 'Blackbird', note: 'The Beatles, fingerpicking rite of passage', lit: true },
      { x: 840, y: 240, label: 'Take On Me', note: 'a-ha — yes, on guitar', lit: true },
      { x: 905, y: 200, label: 'Black', note: 'Pearl Jam, played until the neighbors knew it', lit: true },
      { x: 855, y: 320, label: 'first own song', note: 'still a hum without a name', lit: false, quest: 'four chords that are mine, start to finish' },
    ],
  },
  {
    id: 'nihongo',
    name: '日本語 · japanese',
    color: 'oklch(0.78 0.11 350)',
    labelAt: [470, 360],
    stars: [
      { x: 420, y: 260, label: 'ひらがな', note: 'the first alphabet fell', lit: true },
      { x: 490, y: 290, label: 'カタカナ', note: 'the second one too', lit: true },
      { x: 560, y: 265, label: 'Tae Kim', note: 'grammar, chapter by chapter', lit: true },
      { x: 530, y: 340, label: 'first manga raw', note: 'no translation, no mercy', lit: false, quest: 'finish Tae Kim, then buy one and struggle' },
      { x: 610, y: 320, label: 'JLPT N5', note: 'making it official', lit: false, quest: '~800 words, kanji deck, a December session' },
    ],
  },
  {
