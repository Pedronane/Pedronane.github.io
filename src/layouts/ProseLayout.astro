---
import Layout from './Layout.astro';

const { frontmatter } = Astro.props;
---

<Layout title={`${frontmatter.title} · Pietro Marchesi`} description={frontmatter.description}>
  <main class="prose page">
    <p class="mono-label kicker">{frontmatter.kicker}</p>
    <h1>{frontmatter.title}</h1>
    <slot />
  </main>
</Layout>

<style>
  .page {
    padding-top: clamp(7rem, 16vh, 10rem);
    padding-bottom: var(--space-section);
  }

  h1 {
    font-size: clamp(1.7rem, 4.5vw, 2.6rem);
    font-weight: 700;
    margin-bottom: 2rem;
  }

  .kicker {
    color: var(--cyan);
    margin-bottom: 0.8rem;
  }
</style>
