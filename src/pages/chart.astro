---

<Layout title="Star chart · Pietro Marchesi" description="My passions mapped as constellations — filled stars are reached, hollow ones are waiting.">
  <main class="chart-page">
    <header class="prose">
      <p class="mono-label kicker">celestial cartography</p>
      <h1>Star chart</h1>
      <p>
        My interests as constellations. <strong>Filled stars are reached</strong> —
        hollow ones are still waiting for their light. Tap a star to read it; the
        hollow ones show what it takes to light them.
      </p>
    </header>

    <div class="chart-wrap">
      <svg id="chart" viewBox="0 0 1000 620" role="img" aria-label="Constellation map of interests: cybersecurity, space, guitar, japanese, books, linux">
        {constellations.map((c) => (
          <g class="constellation" id={`c-${c.id}`} style={`--c: ${c.color}`}>
            <polyline
              points={c.stars.map((s) => `${s.x},${s.y}`).join(' ')}
              fill="none"
              stroke={c.color}
              stroke-opacity="0.28"
              stroke-width="1"
            />
            {c.stars.map((s) => (
              <g class="star" data-label={s.label} data-note={s.note} data-lit={s.lit} data-quest={s.quest}>
                <circle class="hit" cx={s.x} cy={s.y} r="14" fill="transparent" />
                {s.lit ? (
                  <circle class="dot" cx={s.x} cy={s.y} r="4" fill={c.color} />
                ) : (
                  <circle class="dot" cx={s.x} cy={s.y} r="3.5" fill="none" stroke={c.color} stroke-width="1.2" stroke-dasharray="2 2.5" />
                )}
              </g>
            ))}
            <text x={c.labelAt[0]} y={c.labelAt[1]} fill={c.color} fill-opacity="0.75" text-anchor="middle">{c.name}</text>
          </g>
        ))}
      </svg>
      <div id="tooltip" class="tooltip mono-label" hidden></div>
    </div>

    <p class="prose legend mono-label">
      ● reached &nbsp; ◌ waiting for light — the chart grows with me
    </p>
  </main>
</Layout>

<style>
  .chart-page {
    padding-top: clamp(7rem, 16vh, 10rem);
    padding-bottom: var(--space-section);
  }

  header h1 {
    font-size: clamp(1.7rem, 4.5vw, 2.6rem);
    font-weight: 700;
    margin-bottom: 1.4rem;
  }

  .kicker {
    color: var(--cyan);
    margin-bottom: 0.8rem;
  }

  .chart-wrap {
    position: relative;
    max-width: 68rem;
    margin: 3rem auto 0;
    padding-inline: 1rem;
  }

  #chart {
    width: 100%;
    height: auto;
    display: block;
  }

  .constellation text {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
  }

  .constellation.dim {
    opacity: 0.22;
    transition: opacity 0.5s var(--ease-quart);
  }

  .constellation {
    transition: opacity 0.5s var(--ease-quart);
  }

  .star {
    cursor: help;
  }

  .star .dot {
    transition: transform 0.25s var(--ease-quart);
    transform-origin: center;
    transform-box: fill-box;
  }

  .star:hover .dot,
  .star.sel .dot {
    transform: scale(1.7);
  }

  @media (hover: none) {
    .hit { r: 24; }

    .constellation text { font-size: 16px; }

    .tooltip {
      white-space: normal;
      width: max-content;
      max-width: min(15rem, 62vw);
      text-align: center;
    }
  }

  .tooltip {
    position: absolute;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 0.45rem 0.8rem;
    color: var(--ink);
    pointer-events: none;
    white-space: nowrap;
    z-index: 5;
    translate: -50% calc(-100% - 10px);
  }

  .tooltip :global(.note) {
    display: block;
    color: var(--faint);
  }

  .tooltip :global(.quest) {
    display: block;
    color: var(--amber);
    margin-top: 0.2rem;
  }

  .tooltip[hidden] {
    display: none;
  }

  .legend {
    text-align: center;
    margin-top: 2.5rem;
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
  const svg = document.getElementById('chart');
  if (!svg || svg.dataset.init) return;
  svg.dataset.init = '1';
  const tooltip = document.getElementById('tooltip')!;
  const wrap = tooltip.parentElement!;
  const coarse = matchMedia('(hover: none)').matches;
  let pinned: SVGGElement | null = null;

  const setPinned = (star: SVGGElement | null) => {
    pinned?.classList.remove('sel');
    pinned = star;
    pinned?.classList.add('sel');
  };

  if (!coarse) {
    svg.addEventListener('pointerover', (e) => {
      const star = (e.target as Element).closest('.star') as SVGGElement | null;
      if (!star || pinned) return;
      show(star, false);
    });

    svg.addEventListener('pointerout', (e) => {
      if (!pinned && (e.target as Element).closest('.star')) tooltip.hidden = true;
    });
  }

  document.addEventListener('click', (e) => {
    const star = (e.target as Element).closest?.('.star') as SVGGElement | null;
    if (!star || star === pinned) {
      setPinned(null);
      tooltip.hidden = true;
      return;
    }
    setPinned(star);
    show(star, true);
  });

  function show(star: SVGGElement, withQuest: boolean) {
    const lit = star.dataset.lit === 'true';
    const quest = withQuest && star.dataset.quest ? `<span class="quest">→ ${star.dataset.quest}</span>` : '';
    tooltip.innerHTML = `<strong>${star.dataset.label}</strong><span class="note">${star.dataset.note}${lit ? '' : ' · not yet lit'}</span>${quest}`;
    const dot = star.querySelector('.dot')!.getBoundingClientRect();
    const box = wrap.getBoundingClientRect();
    tooltip.hidden = false;
    const half = tooltip.offsetWidth / 2;
    const cx = dot.x + dot.width / 2 - box.x;
    tooltip.style.left = `${Math.max(half + 4, Math.min(cx, box.width - half - 4))}px`;
    tooltip.style.top = `${dot.y - box.y}px`;
  }

  const hash = window.location.hash.slice(1);
  if (hash) {
    const target = document.getElementById(`c-${hash}`);
    if (target) {
      for (const c of document.querySelectorAll('.constellation')) {
        if (c !== target) c.classList.add('dim');
      }
      setTimeout(() => {
        for (const c of document.querySelectorAll('.constellation')) c.classList.remove('dim');
      }, 2600);
    }
  }
  });
</script>
